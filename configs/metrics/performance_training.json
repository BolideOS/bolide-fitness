            { "id": "trend_7d", "label": "7-Day Trend", "type": "sparkline" }
        ],
        "formula": "(SleepScore*0.35) + (RecoveryTimeFactor*0.20) + (HRVStatus*0.20) + (AcuteLoadBalance*0.15) + (StressScoreFactor*0.10)"
    },
