    "fields": [
        { "id": "speed",     "label": "Speed",     "type": "speed",    "unit": "km/h" },
        { "id": "distance",  "label": "Distance",  "type": "distance", "unit": "km" },
        { "id": "elev_gain", "label": "Elev Gain",  "type": "distance", "unit": "m" },
        { "id": "pace",      "label": "Pace",       "type": "pace",     "unit": "min/km" },
        { "id": "coords",    "label": "Coordinates","type": "text" }
